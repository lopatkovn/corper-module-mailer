# URL ПРОДАКШН-портала CORPER (для dev-режима на машине разработчика).
# Vite proxy будет направлять /api, /companies, /employees, /auth сюда.
# Если работаете прямо на сервере портала — поменяйте на http://localhost:5000.
VITE_PORTAL_URL=http://10.101.10.181:5000

# Название модуля (согласовано с админом портала)
VITE_MODULE_NAME=mailer

# Секция прав модуля (согласовано с админом портала)
VITE_MODULE_SECTION=notifications
